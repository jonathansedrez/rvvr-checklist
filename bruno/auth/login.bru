meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "test1@reviver.com",
    "password": "test1@"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token", res.body.data.token);
  }
}
